{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/signbridge/contracts/events.schema.json",
  "title": "Signbridge Event Contract",
  "description": "Shared JSON event contract for the Signbridge hackathon scaffold. Event names are stable; additive schema changes are owned by the integration lead.",
  "type": "object",
  "required": ["type"],
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "session.start",
        "landmark.frame",
        "audio.chunk",
        "user.confirmation",
        "record.export",
        "system.status",
        "recognition.partial",
        "recognition.final",
        "translation.final",
        "tts.audio",
        "caption.partial",
        "caption.final",
        "policy.card",
        "question.prompt",
        "record.updated",
        "record.exported",
        "demo.replay"
      ]
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "utterance_id": {
      "type": "string",
      "minLength": 1
    },
    "t_ms": {
      "type": "integer",
      "minimum": 0
    },
    "scenario": {
      "type": "string",
      "minLength": 1
    },
    "consent_record": {
      "type": "boolean"
    },
    "component": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "detail": {
      "type": ["string", "null"]
    },
    "landmarks_version": {
      "type": "string",
      "minLength": 1
    },
    "points": {
      "type": "array"
    },
    "format": {
      "type": "string",
      "minLength": 1
    },
    "sample_rate": {
      "type": "integer",
      "minimum": 1
    },
    "data_b64": {
      "type": "string",
      "contentEncoding": "base64"
    },
    "accepted": {
      "type": "boolean"
    },
    "correction_text": {
      "type": ["string", "null"]
    },
    "tokens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "text": {
      "type": "string",
      "minLength": 1
    },
    "speaker": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "source_title": {
      "type": "string",
      "minLength": 1
    },
    "source_url": {
      "type": "string",
      "minLength": 1
    },
    "quote": {
      "type": "string",
      "minLength": 1
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_title", "source_url", "quote"],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "source_title": {
            "type": "string",
            "minLength": 1
          },
          "publisher": {
            "type": "string",
            "minLength": 1
          },
          "source_url": {
            "type": "string",
            "minLength": 1
          },
          "quote": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "verified": {
            "type": "boolean"
          },
          "verified_on": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "policy_domain": {
      "type": "string",
      "minLength": 1
    },
    "policy_card_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verified": {
      "type": "boolean"
    },
    "item_count": {
      "type": "integer",
      "minimum": 0
    },
    "export_url": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"type": {"const": "session.start"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "session_id", "scenario", "consent_record"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "landmark.frame"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "session_id", "t_ms", "landmarks_version", "points"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "audio.chunk"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "session_id", "t_ms", "format", "sample_rate", "data_b64"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "user.confirmation"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "utterance_id", "accepted", "correction_text"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "record.export"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "session_id", "format"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "system.status"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "component", "status", "detail"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "recognition.partial"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "utterance_id", "tokens", "confidence"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "recognition.final"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "utterance_id", "tokens", "confidence"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "translation.final"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "utterance_id", "text", "confidence"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "tts.audio"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "utterance_id", "format", "data_b64"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "caption.partial"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "speaker", "text"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "caption.final"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "speaker", "text"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "policy.card"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "id", "title", "claim", "source_title", "source_url", "quote"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "question.prompt"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "id", "text"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "record.updated"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "session_id", "item_count"]
      }
    },
    {
      "if": {
        "properties": {"type": {"const": "record.exported"}},
        "required": ["type"]
      },
      "then": {
        "required": ["type", "session_id", "format", "export_url"]
      }
    }
  ]
}
