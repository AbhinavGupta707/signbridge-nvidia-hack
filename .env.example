# Copy to .env for local development. Do not commit real secrets.

SIGNBRIDGE_ENV=development
SIGNBRIDGE_SCENARIO=housing_repair

# Runtime host
RUNTIME_TARGET=unknown
RUNTIME_HOSTNAME=
RUNTIME_LAN_IP=
RUNTIME_GPU_REQUIRED=true

# Web and orchestrator
WEB_PORT=3000
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
ORCHESTRATOR_WS_PATH=/ws

# Local model serving
LLM_PROVIDER=mock
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=qwen3.6-35b-a3b
LLM_TEST_PROMPT=

# NVIDIA NIM
NGC_API_KEY=
NIM_BASE_URL=http://localhost:8000/v1
NIM_MODEL=meta/llama3-8b-instruct
LOCAL_NIM_CACHE=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_MODEL=qwen3.6:35b-a3b-nvfp4

# llama.cpp
LLAMA_CPP_BASE_URL=http://localhost:30000/v1
LLAMA_CPP_MODEL_PATH=
LLAMA_CPP_PORT=30000
LLAMA_CPP_CTX_SIZE=8192
LLAMA_CPP_GPU_LAYERS=99

# Voice providers
ASR_PROVIDER=mock
TTS_PROVIDER=mock
VOICE_PROBE_ALLOW_NETWORK=false

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_ON_DEVICE_AVAILABLE=false
ELEVENLABS_PRIVATE_BASE_URL=
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_ASR_MODEL=scribe_v2_realtime

# Local voice fallbacks
PIPER_VOICE_MODEL=
KOKORO_MODEL_PATH=
WHISPER_CPP_MODEL=
FASTER_WHISPER_MODEL=
CANNED_VOICE_DIR=demo/voice_samples

# Offline proof
OFFLINE_MODE=false
ALLOW_NETWORK_EGRESS=false
SKIP_RUNTIME_PROBES=false
