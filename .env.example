# Copy to .env for local development. Do not commit real secrets.

SIGNBRIDGE_ENV=development
SIGNBRIDGE_SCENARIO=housing_repair

# Web and orchestrator
WEB_PORT=3000
ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8000
ORCHESTRATOR_WS_PATH=/ws

# Local model serving
LLM_PROVIDER=mock
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=qwen3.6-35b-a3b

# Voice providers
ASR_PROVIDER=mock
TTS_PROVIDER=mock
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_ASR_MODEL=scribe_v2_realtime

# Offline proof
OFFLINE_MODE=false
ALLOW_NETWORK_EGRESS=false

